# Live Draft Companion environment example

# Required: DeepSeek API key (direct, https://platform.deepseek.com).
# Copy this file to `.env` and replace the placeholder.
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# DeepSeek direct models (OpenAI-compatible API).
# deepseek-chat = DeepSeek-V3 (veloce, default); deepseek-reasoner = thinking mode (fallback).
LLM_MODEL_PRIMARY=deepseek-chat
LLM_MODEL_FALLBACK_1=deepseek-reasoner

# Draft provider mode.
# `sim` uses FileProvider and is the default build/demo path.
# `live` uses LCUProvider and requires League of Legends client.
DRAFT_PROVIDER_MODE=sim
DRAFT_PROVIDER_FILE=tests/mock_drafts/balanced_mid.json

# Runtime logging.
LOG_LEVEL=INFO
