# Live Draft Companion environment example

# Required: OpenRouter API key.
# Copy this file to `.env` and replace the placeholder.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Strategy A - Free-only default (SPEC_ERRATA v1, ERRATA-003).
LLM_MODEL_PRIMARY=google/gemma-4-31b-it:free
LLM_MODEL_FALLBACK_1=meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL_FALLBACK_2=mistralai/mistral-small-24b-instruct-2501:free
LLM_MODEL_FALLBACK_3=qwen/qwen3-next-80b-a3b-instruct:free

# Strategy B - Budget fallback.
# Uncomment these values only if free-tier rate limits block development
# in 3 consecutive sessions and the switch is documented in INCIDENTS.md.
# LLM_MODEL_PRIMARY=deepseek/deepseek-v4-flash
# LLM_MODEL_FALLBACK_1=google/gemma-4-31b-it:free
# LLM_MODEL_FALLBACK_2=meta-llama/llama-3.3-70b-instruct:free
# LLM_MODEL_FALLBACK_3=mistralai/mistral-small-24b-instruct-2501:free

# Draft provider mode.
# `sim` uses FileProvider and is the default build/demo path.
# `live` uses LCUProvider and requires League of Legends client.
DRAFT_PROVIDER_MODE=sim
DRAFT_PROVIDER_FILE=tests/mock_drafts/balanced_mid.json

# Runtime logging.
LOG_LEVEL=INFO
